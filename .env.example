NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin scripts only. Never expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional production auth email channel. When all three are set, Circlist
# generates Supabase magic links on the server and sends them through Resend.
RESEND_API_KEY=
AUTH_EMAIL_FROM=Circlist <login@example.com>
AUTH_EMAIL_REPLY_TO=
